# Garden Planner API — environment variables
# Copy this to .env and fill in your values

PORT=3001

# IMPORTANT: Change this to a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-secret

# Path to the SQLite database file (relative to server.js)
DB_FILE=./garden.db

# Frontend origin for CORS — set to your actual domain in production
# Use * to allow all origins (fine for development)
ALLOWED_ORIGIN=*
